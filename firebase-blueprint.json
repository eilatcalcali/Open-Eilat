{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the system" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created" }
      },
      "required": ["uid", "email", "role"]
    },
    "CommunityInterest": {
      "title": "Community Interest",
      "description": "Records a user's interest in a specific community",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User's UID" },
        "communityId": { "type": "string", "description": "ID of the community" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the interest was recorded" }
      },
      "required": ["uid", "communityId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/interests/{interestId}": {
      "schema": "CommunityInterest",
      "description": "User interest record"
    }
  }
}
